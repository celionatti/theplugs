# Application environment
APP_ENV=local
APP_KEY=
APP_DEBUG=true
VIEW_DEBUG=true
APP_NAME=ThePlugs
APP_TIMEZONE=Africa/Lagos
APP_URL_PATH=http://theplugs.test/

# Database configuration
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=theplugs
DB_USERNAME=root
DB_PASSWORD=

# Session cookie name
SESSION_COOKIE=plugs_session

# Session lifetime in minutes (120 = 2 hours)
SESSION_LIFETIME=120

# Expire session when browser closes (true/false)
SESSION_EXPIRE_ON_CLOSE=false

# Encrypt session data (true/false) - usually not needed
SESSION_ENCRYPT=false

# Encryption key (only if SESSION_ENCRYPT=true)
# Generate with: php -r "echo bin2hex(random_bytes(32));"
SESSION_KEY=

# Cookie path
SESSION_PATH=/

# Cookie domain (leave empty for current domain)
SESSION_DOMAIN=

# HTTPS only cookie (set to true in production with HTTPS)
SESSION_SECURE_COOKIE=false

# Same-site cookie policy (lax, strict, or none)
SESSION_SAME_SITE=lax

# Garbage collection probability (1-100)
# Higher = more frequent cleanup
SESSION_GC_PROBABILITY=1
SESSION_GC_DIVISOR=100

# Security checks (not recommended for most cases)
SESSION_CHECK_IP=false
SESSION_CHECK_USER_AGENT=false

# Auto-start session on boot
SESSION_AUTO_START=true
