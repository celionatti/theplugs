# =============================================================================
#                     PLUGS FRAMEWORK — ENVIRONMENT CONFIGURATION
# =============================================================================
#
# This file contains the environment-specific settings for your application.
# See `.env.example` for full documentation of every variable.
#
# WARNING: This file contains sensitive credentials. NEVER commit it to
# version control. Add `.env` to your `.gitignore` file.
#
# =============================================================================


# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# The display name of your application.
# Used in page titles, emails, SEO meta tags, and the admin panel.
APP_NAME="My Plugs App"

# The current application environment.
# Options: local, staging, production
# WHY: Controls debug output, error verbosity, asset minification, and
#      security behaviors. ALWAYS set to "production" on live servers.
APP_ENV=local

# Enable or disable detailed error pages and debug info.
# WHY: When true, full stack traces are shown. NEVER enable in production.
APP_DEBUG=true

# The public URL where your application is accessible.
# WHY: Used to generate absolute URLs for links, assets, and OAuth callbacks.
APP_URL=http://plugs.local

# The default timezone for date/time functions and logging.
APP_TIMEZONE=Africa/Lagos

# The application encryption key (base64 encoded, 32 bytes).
# WHY: Used by Encrypter (AES-256-GCM) for cookies, sessions, and data
#      encryption. Generate with: php plugs key:generate
APP_KEY=base64:your_generated_key_here

# Trusted proxies (comma-separated list of IPs or CIDR blocks).
# WHY: Set to "*" to trust all proxies (e.g., behind a load balancer). Use
#      specific IPs in production for security.
TRUSTED_PROXIES=*


# =============================================================================
# CACHE & SESSION CONFIGURATION
# =============================================================================

# Cache backend. Options: file, redis
CACHE_DRIVER=file

# Session backend. Options: file, database
# WHY: "database" is more reliable for multi-server deployments.
SESSION_DRIVER=database

# Session lifetime in minutes before expiry.
SESSION_LIFETIME=120


# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Logging channel. Options: file, daily
# WHY: "daily" rotates logs to prevent disk exhaustion in production.
LOG_CHANNEL=file

# Minimum log severity. Options: debug, info, notice, warning, error
LOG_LEVEL=debug


# =============================================================================
# FILESYSTEM CONFIGURATION
# =============================================================================

# Default storage disk. Options: local, public, s3
FILESYSTEM_DISK=public


# =============================================================================
# QUEUE CONFIGURATION
# =============================================================================

# Queue backend. Options: sync (blocking), database, redis (background)
QUEUE_CONNECTION=sync

# Database table for queued jobs.
QUEUE_TABLE=jobs

# Redis Connection (Optional - needed for redis cache/queue driver)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_PREFIX=plugs_database_


# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Enable CSRF protection. Should ALWAYS be true in production.
CSRF_ENABLED=true

# CSRF Strict Mode — enforces stricter token validation and BREACH protection.
CSRF_STRICT_MODE=true

# Content Security Policy headers. Prevents XSS by controlling allowed sources.
# WHY: Enable after testing to avoid accidentally blocking legitimate resources.
CSP_ENABLED=false

# Cross-Origin Resource Sharing. Enable if frontend is on a different domain.
CORS_ENABLED=false

# Security Shield — real-time rate limiting, bot detection, and threat analysis.
SECURITY_SHIELD=true

# Debug profiler toolbar. MUST be false in production.
PROFILER_ENABLED=true

# Identity Manager for device/session tracking.
AUTH_IDENTITY_ENABLED=true

# Require email verification after registration.
AUTH_VERIFICATION=false


# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database driver. Options: mysql, pgsql, sqlite
DB_CONNECTION=mysql

# Database server connection details.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db_natti
DB_USERNAME=root
DB_PASSWORD=


# =============================================================================
# MAIL CONFIGURATION
# =============================================================================

# Mail transport. Options: smtp, sendmail, mailgun, ses
MAIL_MAILER=smtp

# SMTP server details.
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=

# Encryption. Options: tls (recommended), ssl, null
MAIL_ENCRYPTION=tls

# Sender address and display name for outgoing emails.
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"


# =============================================================================
# HASHING CONFIGURATION
# =============================================================================

# Password hashing algorithm. Options: bcrypt, argon2i, argon2id
# WHY: argon2id is most secure — resistant to GPU and side-channel attacks.
HASH_DRIVER=argon2id


# =============================================================================
# PAYMENT GATEWAY CONFIGURATION (Optional)
# =============================================================================

# Default payment provider. Options: paystack, flutterwave, stripe, paypal
DEFAULT_PAYMENT_PLATFORM=paystack

# Payment mode. Options: test (sandbox), live (real money)
PAYMENT_ENVIRONMENT=test

# Default currency. Examples: NGN, USD, GHS, KES, ZAR, EUR, GBP
PAYMENT_CURRENCY=NGN

# Paystack (https://dashboard.paystack.com/#/settings/developer)
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret_here

# Flutterwave (https://dashboard.flutterwave.com/settings/apis)
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_public_key_here
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_secret_key_here
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TEST-your_encryption_key_here

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal (https://developer.paypal.com/)
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Payoneer (https://developer.payoneer.com/)
PAYONEER_MODE=sandbox
PAYONEER_CLIENT_ID=your_payoneer_client_id
PAYONEER_CLIENT_SECRET=your_payoneer_client_secret
PAYONEER_PROGRAM_ID=your_payoneer_program_id


# =============================================================================
# OAUTH / SOCIAL LOGIN (Optional)
# =============================================================================

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth (https://developers.facebook.com/apps/)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=


# =============================================================================
# AI PROVIDER CONFIGURATION (Optional)
# =============================================================================
# Only configure the provider(s) you plan to use.

# OpenAI (https://platform.openai.com/api-keys)
#OPENAI_API_KEY=

# Google Gemini (https://aistudio.google.com/apikey)
#GEMINI_API_KEY=

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=
#GROQ_MODEL=openai/gpt-oss-120b

# OpenRouter (https://openrouter.ai/keys)
#OPENROUTER_API_KEY=
